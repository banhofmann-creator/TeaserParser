{
  "permissions": {
    "allow": [
      "Bash(uv run:*)",
      "Bash(chmod +x:*)",
      "Bash(git diff:*)",
      "Bash(git status:*)",
      "Write(planning/REVIEW.md)",
      "WebSearch",
      "WebFetch(domain:www.npmjs.com)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:docs.litellm.ai)",
      "WebFetch(domain:massive.com)",
      "mcp__plugin_context7_context7__resolve-library-id",
      "mcp__plugin_context7_context7__query-docs",
      "WebFetch(domain:react-leaflet.js.org)",
      "Bash(mkdir:*)",
      "Bash(uv init:*)",
      "Bash(uv add:*)",
      "Bash(npx create-next-app@latest:*)",
      "Bash(npm install:*)",
      "Bash(npm run:*)",
      "Bash(docker compose:*)",
      "Bash(docker version:*)",
      "Bash(ls:*)",
      "Bash(uv lock:*)",
      "Bash(rm:*)",
      "Bash(mv .venv:*)",
      "Bash(uv:*)",
      "Bash(UV_VENV_CLEAR=1 uv venv:*)",
      "Bash(taskkill:*)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "agent",
            "timeout": 120,
            "statusMessage": "Running independent code review..."
          }
        ]
      }
    ]
  }
}
